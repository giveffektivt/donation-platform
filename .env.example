QUICKPAY_DONATION_API_KEY=quickpay-apikey
QUICKPAY_DONATION_PRIVATE_KEY=quickpay-privatekey
QUICKPAY_MEMBERSHIP_API_KEY=quickpay-apikey
QUICKPAY_MEMBERSHIP_PRIVATE_KEY=quickpay-privatekey

# Betalingsservice (Mastercard BS Creditor API). SIGNING_KEY_BASE64 is the .pem
# private key file content base64-encoded (`base64 -w0 < key.pem`).
# Sandbox base URL: https://mtf.oauth.payments.mastercard.dk/betalingsservice/bs-creditor-api-sandbox
# Production base URL: https://oauth.payments.mastercard.dk/betalingsservice/bs-creditor-api
BETALINGSSERVICE_BASE_URL=https://mtf.oauth.payments.mastercard.dk/betalingsservice/bs-creditor-api-sandbox
BETALINGSSERVICE_CONSUMER_KEY=betalingsservice-consumer-key
BETALINGSSERVICE_SIGNING_KEY_BASE64=base64-of-pem-private-key
BETALINGSSERVICE_PBS_NUMBER=00000000
BETALINGSSERVICE_DEBTOR_GROUP_NUMBER=0000

# Mastercard Open Banking Europe (Aiia) — used to charge bank donations.
# Sandbox: https://api-sandbox.aiia.eu  (sign up at https://portal.aiia.eu)
# Production: https://api.aiia.eu
# CLIENT_ID / CLIENT_SECRET are the app credentials from the Aiia developer portal.
# DESTINATION_ID is the registered creditor account that receives the payment.
# WEBHOOK_SECRET is the shared secret used to sign the X-Viia-Signature (HMAC-SHA256) header.
OPEN_BANKING_BASE_URL=https://api-sandbox.aiia.eu
OPEN_BANKING_CLIENT_ID=aiia-client-id
OPEN_BANKING_CLIENT_SECRET=aiia-client-secret
OPEN_BANKING_DESTINATION_ID=aiia-destination-id
OPEN_BANKING_WEBHOOK_SECRET=aiia-webhook-secret

SUCCESS_URL=https://giveffektivt.dk/tak-for-din-stotte/
SUCCESS_URL_MEMBERSHIP_ONLY=https://giveffektivt.dk/velkommen-medlem/
RENEW_PAYMENT_INFO_URL=https://giveffektivt.dk/forny-betaling
SUCCESS_URL_NEW_PAYMENT_INFO=https://giveffektivt.dk/fornyelse-ok

CRON_API_KEY=cron-apikey
GAVEBREV_API_KEY=gavebrev-apikey
FAILED_RECURRING_DONATIONS_API_KEY=failed-recurring-donations-apikey

PGUSER=donation_platform
PGPASSWORD=CHANGEME
PGDATABASE=giveffektivt
PGHOST=localhost
PGPORT=5432
